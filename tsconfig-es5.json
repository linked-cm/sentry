{
  "compilerOptions": {
    "module": "commonjs",
    "sourceMap": true,
    "target": "es5",
    "outDir": "lib",
    "declaration": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "downlevelIteration": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "types": ["node", "react", "react-dom"],
    "jsx": "react",
    "baseUrl": "./",
    "rootDir": "src"
  },
  "files": ["./src/index.ts"],
  "include": ["./src/backend.ts"]
}
